{
  "expo": {
    "name": "Guardian Angel",
    "slug": "guardian-angel",
    "version": "0.1.0",
    "orientation": "default",
    "scheme": "guardian-angel",
    "userInterfaceStyle": "light",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#f7f9fc"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.guardianangel.mobile"
    },
    "android": {
      "package": "com.guardianangel.mobile",
      "softwareKeyboardLayoutMode": "resize"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-notifications",
        {
          "color": "#ff5a5f",
          "defaultChannel": "wellbeing-check-ins"
        }
      ],
      "expo-secure-store"
    ]
  }
}
